rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Allow anyone to read content (Home page, FAQs, Products, Gallery)
      allow read: if true;
      
      // Allow only specific admin emails to write/modify database records
      allow write: if request.auth != null && 
        (request.auth.token.email == 'admin@nakshatracctv.com' || 
         request.auth.token.email == 'ramesh@nakshatracctv.com' ||
         request.auth.token.email == 'ramesh@gmail.com');
    }
  }
}
