rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow public read access to uploaded product and gallery images
      allow read: if true;
      
      // Allow only specific admin emails to upload files
      allow write: if request.auth != null && 
        (request.auth.token.email == 'admin@nakshatracctv.com' || 
         request.auth.token.email == 'ramesh@nakshatracctv.com' ||
         request.auth.token.email == 'ramesh@gmail.com');
    }
  }
}
